# Ignore files generated by Lumera Editorial Workflow environment

# Dependencies
vendor/
library/

# Logs and temp files
*.log
*.tmp
error_log

# Keep cache folder but ignore its contents
cache/*
!cache/.gitkeep

# cache files
cache/*.html
cache/*.wiz
cache/*.json
cache/*.php
cache/*.gz
cache/*.json.gz
cache/t_cache/*
!cache/t_cache/.gitkeep
cache/t_compile/*
!cache/t_compile/.gitkeep
cache/t_config/*
!cache/t_config/.gitkeep
cache/_db/*
!cache/_db/.gitkeep
cache/HTML/*
!cache/HTML/.gitkeep

# Environment
.env
.env.local
*.env.*
.user.ini
php.ini
config.inc.php

# Editor/IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
*.o
*.obj
*.exe
*.dll
*.so
*.a
*.out
dist/
build/
target/
coverage/
htmlcov/
*.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
.Python
*.egg-info/
.eggs/
.mypy_cache/
.pytest_cache/
.tox/
.coverage

# Node.js specific
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java specific
*.class
*.jar
*.war
*.ear
.gradle/
build/

# Go specific
*.exe
*.exe~
*.dll
*.so
*.dylib

# Ruby specific
*.gem
*.rbc
capybara-*.html
.rspec
/db
/doc/api
/.document
.ruby-version
.bundle
.vendor

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
*.tpl.php