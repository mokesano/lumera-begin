<install version="2.4.8.2">
	<code function="createDirectories"/>
	<code function="createDatabase"/>

	<!-- SEP schema components -->
	<schema file="lib/sep/xml/schema/common.xml" />
	<schema file="lib/sep/xml/schema/groups.xml" />
	<schema file="lib/sep/xml/schema/log.xml" />
	<schema file="lib/sep/xml/schema/controlledVocab.xml" />
	<schema file="lib/sep/xml/schema/scheduledTasks.xml" />
	<schema file="lib/sep/xml/schema/temporaryFiles.xml" />
	<schema file="lib/sep/xml/schema/signoff.xml" />
	<schema file="lib/sep/xml/schema/announcements.xml" />
	<schema file="lib/sep/xml/schema/reviews.xml" />
	<schema file="lib/sep/xml/schema/reviewForms.xml" />
	<schema file="lib/sep/xml/schema/submissions.xml" />
	<schema file="lib/sep/xml/schema/comments.xml" />
	<schema file="lib/sep/xml/schema/notes.xml" />
	<schema file="lib/sep/xml/schema/metadata.xml" />
	<schema file="lib/sep/xml/schema/gifts.xml" />
	<schema file="lib/sep/xml/schema/mutex.xml" />
	<schema file="lib/sep/xml/schema/tombstone.xml" />
	<schema file="lib/sep/xml/schema/metrics.xml" />

	<!-- SEP data components -->
	<data file="lib/sep/xml/mutexData.xml" />
	
	<!-- CLA schema -->
	<schema file="dbscripts/xml/cla_schema.xml" />

	<!-- CLOB/Text indexes handled differently for MySQL and PostgreSQL -->
	<data file="dbscripts/xml/indexes.xml" />

	<!-- Other install tasks -->
	<code function="createData"/>
	<code function="createConfig"/>
	<code function="addPluginVersions"/>
</install>
